DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,tasks.example.com

JIRA_BASE_URL=https://api.atlassian.com
JIRA_CLOUD_ID=replace-with-jira-cloud-id
JIRA_EMAIL=replace-with-jira-email
JIRA_API_TOKEN=replace-with-jira-api-token

ALLOWED_PROJECT_KEYS=SL,EXCO
MCP_API_KEY=replace-with-shared-api-key

GOOGLE_SHEETS_PROJECT_ID=replace-with-google-project-id
GOOGLE_SHEETS_CLIENT_ID=replace-with-google-client-id
GOOGLE_SHEETS_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_SHEETS_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_SHEETS_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_SHEETS_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_SHEETS_REDIRECT_URI=http://localhost
GOOGLE_SHEETS_REFRESH_TOKEN=replace-with-google-refresh-token
GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=replace-with-default-spreadsheet-id
